#!/usr/bin/env bash
# Expand root ext4 partition to fill the disk (NVMe/SD) on first boot.
set -euo pipefail

MARKER=/var/lib/ultra/root-expanded
ROOT_PART=$(findmnt -n -o SOURCE /)
DISK=$(lsblk -n -o PKNAME "${ROOT_PART}")
PART_NUM=$(lsblk -n -o PARTN "${ROOT_PART}")

if [ -f "${MARKER}" ]; then
  exit 0
fi

growpart "/dev/${DISK}" "${PART_NUM}" || true
partprobe "/dev/${DISK}" 2>/dev/null || true
resize2fs "${ROOT_PART}" || true

mkdir -p /var/lib/ultra
touch "${MARKER}"
