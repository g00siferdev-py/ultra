[Unit]
Description=Pull Home Assistant container image (Linux Ultra first boot)
After=docker.service network-online.target
Wants=network-online.target
Requires=docker.service
ConditionPathExists=!/var/lib/homeassistant/.docker-image-ready

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/usr/local/sbin/ultra-homeassistant pull
Restart=on-failure
RestartSec=30

[Install]
WantedBy=multi-user.target
