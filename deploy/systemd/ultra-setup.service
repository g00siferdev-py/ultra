[Unit]
Description=Linux Ultra first-boot setup wizard
After=network-online.target
ConditionPathExists=!/var/lib/ultra/setup-complete
Before=ultra-tasks.timer

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/usr/local/bin/ultra setup --prod
StandardInput=tty
StandardOutput=tty
StandardError=tty
TTYPath=/dev/tty1
TTYReset=yes
TTYVHangup=yes

[Install]
WantedBy=multi-user.target
